#!/bin/bash
set -euo pipefail

# This file is installed root-owned and is the only privileged operation
# interface exposed to the provisioned account.
PATH=/usr/bin:/bin:/usr/sbin:/sbin
export PATH
umask 077

STATUS_ALLOWLIST="/etc/homelab-agent-access/status-allowlist"
LOG_ALLOWLIST="/etc/homelab-agent-access/log-allowlist"
UNIT_PATTERN='[A-Za-z0-9_.@:][A-Za-z0-9_.@:-]*'

usage() {
  echo "Usage: status UNIT | logs UNIT LINES | ports | hardware" >&2
  exit 64
}

COMMAND_TERM_SECONDS=14
COMMAND_KILL_GRACE_SECONDS=1
COMMAND_MAX_SECONDS=15
MAX_STREAM_BYTES=524288
CAPTURE_FILE_BLOCKS=2048
BOUND_STDOUT=""
BOUND_STDERR=""
BOUND_RM_BIN=""

runtime_tool() {
  local candidate
  case "$1" in
    timeout) set -- /usr/bin/timeout /bin/timeout ;;
    mktemp) set -- /usr/bin/mktemp /bin/mktemp ;;
    head) set -- /usr/bin/head /bin/head ;;
    rm) set -- /usr/bin/rm /bin/rm ;;
    stat) set -- /usr/bin/stat /bin/stat ;;
    *) return 1 ;;
  esac
  for candidate in "$@"; do
    if [[ -x "$candidate" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
  return 1
}

# shellcheck disable=SC2329 # Invoked by the EXIT trap below.
cleanup_bounded_files() {
  if [[ -n "$BOUND_RM_BIN" ]]; then
    [[ -n "$BOUND_STDOUT" ]] && "$BOUND_RM_BIN" -f -- "$BOUND_STDOUT" 2>/dev/null || true
    [[ -n "$BOUND_STDERR" ]] && "$BOUND_RM_BIN" -f -- "$BOUND_STDERR" 2>/dev/null || true
  fi
}
trap cleanup_bounded_files EXIT

run_bounded() {
  local timeout_bin mktemp_bin head_bin stat_bin command_rc
  local stdout_bytes stderr_bytes stdout_limit stderr_limit
  local emit_rc=0 stderr_emit_rc=0 cleanup_rc=0
  local truncated=false

  timeout_bin="$(runtime_tool timeout)" || {
    echo "timeout is unavailable for bounded diagnostics" >&2
    return 69
  }
  mktemp_bin="$(runtime_tool mktemp)" || {
    echo "mktemp is unavailable for bounded diagnostics" >&2
    return 69
  }
  head_bin="$(runtime_tool head)" || {
    echo "head is unavailable for bounded diagnostics" >&2
    return 69
  }
  BOUND_RM_BIN="$(runtime_tool rm)" || {
    echo "rm is unavailable for bounded diagnostics" >&2
    return 69
  }
  stat_bin="$(runtime_tool stat)" || {
    echo "stat is unavailable for bounded diagnostics" >&2
    return 69
  }

  BOUND_STDOUT="$("$mktemp_bin")"
  BOUND_STDERR="$("$mktemp_bin")"
  set +e
  (
    ulimit -f "$CAPTURE_FILE_BLOCKS"
    exec "$timeout_bin" --signal=TERM \
      --kill-after="${COMMAND_KILL_GRACE_SECONDS}s" \
      "${COMMAND_TERM_SECONDS}s" "$@"
  ) > "$BOUND_STDOUT" 2> "$BOUND_STDERR"
  command_rc=$?
  set -e

  stdout_bytes="$("$stat_bin" -c '%s' "$BOUND_STDOUT")"
  stderr_bytes="$("$stat_bin" -c '%s' "$BOUND_STDERR")"
  if [[ ! "$stdout_bytes" =~ ^[0-9]+$ || ! "$stderr_bytes" =~ ^[0-9]+$ ]]; then
    echo "failed to measure diagnostic output" >&2
    return 69
  fi
  stdout_limit="$stdout_bytes"
  stderr_limit="$stderr_bytes"
  if (( stdout_bytes > MAX_STREAM_BYTES )); then
    stdout_limit="$MAX_STREAM_BYTES"
    truncated=true
  fi
  if (( stderr_bytes > MAX_STREAM_BYTES )); then
    stderr_limit="$MAX_STREAM_BYTES"
    truncated=true
  fi

  set +e
  "$head_bin" -c "$stdout_limit" -- "$BOUND_STDOUT"
  emit_rc=$?
  "$head_bin" -c "$stderr_limit" -- "$BOUND_STDERR" >&2
  stderr_emit_rc=$?
  (( emit_rc == 0 )) && emit_rc="$stderr_emit_rc"
  "$BOUND_RM_BIN" -f -- "$BOUND_STDOUT" "$BOUND_STDERR"
  cleanup_rc=$?
  if (( cleanup_rc == 0 )); then
    BOUND_STDOUT=""
    BOUND_STDERR=""
  elif (( emit_rc == 0 )); then
    emit_rc="$cleanup_rc"
  fi
  set -e

  if (( emit_rc != 0 )); then
    return 74
  fi
  if (( command_rc == 124 || command_rc == 137 )); then
    [[ "$truncated" == true ]] && \
      echo "Diagnostic output also exceeded the 512 KiB per-stream limit" >&2
    echo "Diagnostic command reached its deadline (${COMMAND_MAX_SECONDS}-second hard limit)" >&2
    return 124
  fi
  if [[ "$truncated" == true ]]; then
    echo "Diagnostic output exceeded the 512 KiB per-stream limit" >&2
    return 75
  fi
  return "$command_rc"
}

hardware_output() {
  local found=0
  printf '%s\n' '== CPU =='
  if [[ -x /usr/bin/lscpu ]]; then
    /usr/bin/lscpu
    found=1
  fi
  printf '%s\n' '== Block devices =='
  if [[ -x /usr/bin/lsblk ]]; then
    /usr/bin/lsblk -o NAME,TYPE,SIZE,MODEL,ROTA,MOUNTPOINT
    found=1
  fi
  printf '%s\n' '== Memory =='
  if [[ -x /usr/bin/free ]]; then
    /usr/bin/free -h
    found=1
  fi
  printf '%s\n' '== Sensors =='
  if [[ -x /usr/bin/sensors ]]; then
    /usr/bin/sensors
    found=1
  else
    echo 'sensors is not installed'
  fi
  (( found == 1 )) && return 0
  echo "No supported hardware commands are available on this host" >&2
  return 69
}

if [[ $# -eq 1 && "$1" == --internal-hardware ]]; then
  hardware_output
  exit $?
fi
[[ $# -eq 0 ]] || usage

allowlist_contains() {
  local file="$1" requested="$2" line stat_command found=false entries=0 bytes
  if [[ ! -f "$file" || -L "$file" || ! -r "$file" ]]; then
    echo "allowlist is missing or inaccessible: $file" >&2
    return 69
  fi
  if [[ -x /usr/bin/stat ]]; then
    stat_command=/usr/bin/stat
  elif [[ -x /bin/stat ]]; then
    stat_command=/bin/stat
  else
    echo "stat is unavailable for allowlist verification" >&2
    return 69
  fi
  if [[ "$("$stat_command" -c '%u' "$file")" -ne 0 || \
        "$("$stat_command" -c '%a' "$file")" != 400 ]]; then
    echo "allowlist ownership or permissions are unsafe: $file" >&2
    return 69
  fi
  bytes="$("$stat_command" -c '%s' "$file")"
  if [[ ! "$bytes" =~ ^[0-9]+$ || "$bytes" -gt 65536 ]]; then
    echo "allowlist exceeds the size limit: $file" >&2
    return 69
  fi
  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ "$line" != *$'\r'* ]] || {
      echo "allowlist contains a carriage return: $file" >&2
      return 69
    }
    [[ -z "$line" || "$line" == \#* ]] && continue
    entries=$((entries + 1))
    (( entries <= 1024 )) || {
      echo "allowlist exceeds the unit limit: $file" >&2
      return 69
    }
    [[ "$line" =~ ^$UNIT_PATTERN$ ]] || {
      echo "allowlist contains an invalid systemd unit: $file" >&2
      return 69
    }
    [[ "$line" == "$requested" ]] && found=true
  done < "$file"
  [[ "$found" == true ]] && return 0
  return 1
}

require_allowed() {
  local rc
  if allowlist_contains "$1" "$2"; then
    return 0
  else
    rc=$?
  fi
  if (( rc == 1 )); then
    echo "systemd unit is not allowlisted: $2" >&2
    exit 77
  fi
  exit "$rc"
}

IFS= read -r request || usage
# A request is exactly one line. Reject trailing input rather than ignoring it.
if IFS= read -r _; then
  echo "Invalid operation: multiple input lines" >&2
  exit 64
fi

if [[ "$request" =~ ^status[[:space:]]+($UNIT_PATTERN)$ ]]; then
  unit="${BASH_REMATCH[1]}"
  require_allowed "$STATUS_ALLOWLIST" "$unit"
  if [[ -x /usr/bin/systemctl ]]; then
    run_bounded /usr/bin/systemctl show --no-pager \
      --property=Id,LoadState,ActiveState,SubState,UnitFileState "$unit"
    exit $?
  fi
  echo "systemctl is not available on this host" >&2
  exit 69
fi

if [[ "$request" =~ ^logs[[:space:]]+($UNIT_PATTERN)[[:space:]]+([0-9]{1,4})$ ]]; then
  unit="${BASH_REMATCH[1]}"
  lines="${BASH_REMATCH[2]}"
  require_allowed "$LOG_ALLOWLIST" "$unit"
  lines=$((10#$lines))
  if (( lines < 1 || lines > 500 )); then
    echo "Log line limit must be between 1 and 500" >&2
    exit 64
  fi
  if [[ -x /usr/bin/journalctl ]]; then
    run_bounded /usr/bin/journalctl --no-pager --output=short-iso \
      -n "$lines" -u "$unit"
    exit $?
  fi
  echo "journalctl is not available on this host" >&2
  exit 69
fi

if [[ "$request" == ports ]]; then
  if [[ -x /usr/bin/ss ]]; then
    run_bounded /usr/bin/ss -lntup
    exit $?
  elif [[ -x /bin/ss ]]; then
    run_bounded /bin/ss -lntup
    exit $?
  fi
  echo "ss is not available on this host" >&2
  exit 69
fi

if [[ "$request" == hardware ]]; then
  run_bounded /usr/local/sbin/homelab-agent-dispatch-root --internal-hardware
  exit $?
fi

usage
