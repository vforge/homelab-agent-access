#!/bin/bash
set -euo pipefail

# This file is installed root-owned and is the only privileged operation
# interface exposed to the provisioned account.
PATH=/usr/bin:/bin:/usr/sbin:/sbin
export PATH
umask 077

STATUS_ALLOWLIST="/etc/homelab-agent-access/status-allowlist"
LOG_ALLOWLIST="/etc/homelab-agent-access/log-allowlist"
UNIT_PATTERN='[A-Za-z0-9_.@:][A-Za-z0-9_.@:-]*'

usage() {
  echo "Usage: status UNIT | logs UNIT LINES | ports | hardware" >&2
  exit 64
}

allowlist_contains() {
  local file="$1" requested="$2" line
  if [[ ! -f "$file" || -L "$file" || ! -r "$file" ]]; then
    echo "allowlist is missing or inaccessible: $file" >&2
    return 69
  fi
  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ "$line" != *$'\r'* ]] || {
      echo "allowlist contains a carriage return: $file" >&2
      return 69
    }
    [[ -z "$line" || "$line" == \#* ]] && continue
    [[ "$line" =~ ^$UNIT_PATTERN$ ]] || {
      echo "allowlist contains an invalid systemd unit: $file" >&2
      return 69
    }
    [[ "$line" == "$requested" ]] && return 0
  done < "$file"
  return 1
}

require_allowed() {
  local rc
  if allowlist_contains "$1" "$2"; then
    return 0
  else
    rc=$?
  fi
  if (( rc == 1 )); then
    echo "systemd unit is not allowlisted: $2" >&2
    exit 77
  fi
  exit "$rc"
}

IFS= read -r request || usage
# A request is exactly one line. Reject trailing input rather than ignoring it.
if IFS= read -r _; then
  echo "Invalid operation: multiple input lines" >&2
  exit 64
fi

if [[ "$request" =~ ^status[[:space:]]+($UNIT_PATTERN)$ ]]; then
  unit="${BASH_REMATCH[1]}"
  require_allowed "$STATUS_ALLOWLIST" "$unit"
  if [[ -x /usr/bin/systemctl ]]; then
    exec /usr/bin/systemctl show --no-pager \
      --property=Id,LoadState,ActiveState,SubState,UnitFileState "$unit"
  fi
  echo "systemctl is not available on this host" >&2
  exit 69
fi

if [[ "$request" =~ ^logs[[:space:]]+($UNIT_PATTERN)[[:space:]]+([0-9]{1,4})$ ]]; then
  unit="${BASH_REMATCH[1]}"
  lines="${BASH_REMATCH[2]}"
  require_allowed "$LOG_ALLOWLIST" "$unit"
  lines=$((10#$lines))
  if (( lines < 1 || lines > 500 )); then
    echo "Log line limit must be between 1 and 500" >&2
    exit 64
  fi
  if [[ -x /usr/bin/journalctl ]]; then
    exec /usr/bin/journalctl --no-pager --output=short-iso \
      -n "$lines" -u "$unit"
  fi
  echo "journalctl is not available on this host" >&2
  exit 69
fi

if [[ "$request" == ports ]]; then
  if [[ -x /usr/bin/ss ]]; then
    exec /usr/bin/ss -lntup
  elif [[ -x /bin/ss ]]; then
    exec /bin/ss -lntup
  fi
  echo "ss is not available on this host" >&2
  exit 69
fi

if [[ "$request" == hardware ]]; then
  found=0
  printf '%s\n' '== CPU =='
  if [[ -x /usr/bin/lscpu ]]; then
    /usr/bin/lscpu
    found=1
  fi
  printf '%s\n' '== Block devices =='
  if [[ -x /usr/bin/lsblk ]]; then
    /usr/bin/lsblk -o NAME,TYPE,SIZE,MODEL,ROTA,MOUNTPOINT
    found=1
  fi
  printf '%s\n' '== Memory =='
  if [[ -x /usr/bin/free ]]; then
    /usr/bin/free -h
    found=1
  fi
  printf '%s\n' '== Sensors =='
  if [[ -x /usr/bin/sensors ]]; then
    /usr/bin/sensors
    found=1
  else
    echo 'sensors is not installed'
  fi
  (( found == 1 )) && exit 0
  echo "No supported hardware commands are available on this host" >&2
  exit 69
fi

usage
