#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat >&2 <<'EOF'
Usage: list user@host [options]

Options:
  --json    Emit machine-readable JSON (requires jq on the target)
  --brief   Emit one line per managed account
  --help    Show this help
EOF
  exit 2
}

[[ $# -ge 1 ]] || usage
REMOTE="$1"
shift
FORMAT=table
while [[ $# -gt 0 ]]; do
  case "$1" in
    --json) FORMAT=json; shift ;;
    --brief) FORMAT=brief; shift ;;
    --help) usage ;;
    *) echo "Unknown option: $1" >&2; usage ;;
  esac
done

if [[ "$REMOTE" == -* || ! "$REMOTE" =~ ^[^@[:space:]]+@[^@[:space:]]+$ ]]; then
  echo "Error: remote must be in user@host format: $REMOTE" >&2
  exit 1
fi

ssh \
  -o BatchMode=yes \
  -o RequestTTY=no \
  -o StrictHostKeyChecking=yes \
  -o ConnectTimeout=10 \
  -- "$REMOTE" bash -s -- "$FORMAT" <<'REMOTE_SCRIPT'
set -euo pipefail

[[ $# -eq 1 ]] || { echo "invalid audit payload" >&2; exit 64; }
FORMAT="$1"
[[ "$FORMAT" == table || "$FORMAT" == brief || "$FORMAT" == json ]] || {
  echo "invalid output format" >&2
  exit 64
}

for required in getent id grep; do
  command -v "$required" >/dev/null 2>&1 || {
    echo "required remote command is missing: $required" >&2
    exit 69
  }
done
if [[ "$FORMAT" == json ]]; then
  command -v jq >/dev/null 2>&1 || {
    echo "--json requires jq on the target" >&2
    exit 69
  }
fi

MANAGED_DIR="/etc/homelab-agent-access"
ACCOUNTS_DIR="$MANAGED_DIR/accounts"
SUDOERS_DIR="/etc/sudoers.d"
STATUS_ALLOWLIST="$MANAGED_DIR/status-allowlist"
LOG_ALLOWLIST="$MANAGED_DIR/log-allowlist"
status_allowlist_state=missing
log_allowlist_state=missing
[[ -f "$STATUS_ALLOWLIST" && ! -L "$STATUS_ALLOWLIST" ]] && status_allowlist_state=present
[[ -f "$LOG_ALLOWLIST" && ! -L "$LOG_ALLOWLIST" ]] && log_allowlist_state=present
users=()
if [[ -d "$ACCOUNTS_DIR" && ! -L "$ACCOUNTS_DIR" ]]; then
  for marker in "$ACCOUNTS_DIR"/*; do
    [[ -f "$marker" && ! -L "$marker" ]] || continue
    user="${marker##*/}"
    [[ "$user" =~ ^[a-z_][a-z0-9_-]{0,31}$ && "$user" != root ]] || continue
    grep -q '^version=3$' "$marker" || continue
    users+=("$user")
  done
fi
# Version-2 markers are listed as legacy so administrators can see accounts that
# require an explicit create/update migration.
if [[ -d "$MANAGED_DIR" && ! -L "$MANAGED_DIR" ]]; then
  for marker in "$MANAGED_DIR"/*; do
    [[ -f "$marker" && ! -L "$marker" ]] || continue
    user="${marker##*/}"
    [[ "$user" =~ ^[a-z_][a-z0-9_-]{0,31}$ && "$user" != root ]] || continue
    [[ "$(<"$marker")" == version=2 ]] || continue
    users+=("$user")
  done
fi

home_for_user() {
  local user="$1" entry home _
  entry="$(getent passwd "$user" 2>/dev/null || true)"
  if [[ -z "$entry" ]]; then
    printf '%s\n' unknown
    return
  fi
  IFS=: read -r _ _ _ _ _ home _ <<< "$entry"
  [[ -n "$home" ]] && printf '%s\n' "$home" || printf '%s\n' unknown
}

shell_for_user() {
  local user="$1" entry shell _
  entry="$(getent passwd "$user" 2>/dev/null || true)"
  if [[ -z "$entry" ]]; then
    printf '%s\n' absent
    return
  fi
  IFS=: read -r _ _ _ _ _ _ shell <<< "$entry"
  [[ -n "$shell" ]] && printf '%s\n' "$shell" || printf '%s\n' unknown
}

version_for_user() {
  local user="$1"
  if [[ -f "$ACCOUNTS_DIR/$user" && ! -L "$ACCOUNTS_DIR/$user" ]]; then
    printf '%s\n' 3
  else
    printf '%s\n' 2
  fi
}

if [[ "$FORMAT" == json ]]; then
  result='[]'
  for user in "${users[@]}"; do
    home="$(home_for_user "$user")"
    shell="$(shell_for_user "$user")"
    metadata_version="$(version_for_user "$user")"
    state=present
    id "$user" >/dev/null 2>&1 || state=stale
    key_state=missing
    [[ -f "$home/.ssh/authorized_keys" ]] && key_state=present
    sudo_state=missing
    [[ -f "$SUDOERS_DIR/homelab-agent-$user" ]] && sudo_state=present
    result="$(jq --arg user "$user" \
      --arg home "$home" \
      --arg shell "$shell" \
      --arg state "$state" \
      --arg key_state "$key_state" \
      --arg sudo_state "$sudo_state" \
      --arg status_allowlist "$status_allowlist_state" \
      --arg log_allowlist "$log_allowlist_state" \
      --argjson metadata_version "$metadata_version" \
      '. + [{user: $user, home: $home, shell: $shell, state: $state,
        metadata_version: $metadata_version,
        authorized_key: $key_state, sudoers: $sudo_state,
        status_allowlist: $status_allowlist, log_allowlist: $log_allowlist,
        operations: ["status", "logs", "ports", "hardware"]}]' <<< "$result")"
  done
  jq . <<< "$result"
  exit 0
fi

if [[ "$FORMAT" == brief ]]; then
  for user in "${users[@]}"; do
    home="$(home_for_user "$user")"
    state=present
    id "$user" >/dev/null 2>&1 || state=stale
    metadata_version="$(version_for_user "$user")"
    echo "$user home=$home state=$state metadata_version=$metadata_version"
  done
  [[ ${#users[@]} -gt 0 ]] || echo "No managed accounts found."
  exit 0
fi

printf '=== Managed homelab agent accounts on %s ===\n\n' "$(hostname 2>/dev/null || printf '%s' server)"
if [[ ${#users[@]} -eq 0 ]]; then
  echo 'No managed accounts found.'
  exit 0
fi
for user in "${users[@]}"; do
  home="$(home_for_user "$user")"
  shell="$(shell_for_user "$user")"
  metadata_version="$(version_for_user "$user")"
  state=present
  id "$user" >/dev/null 2>&1 || state=stale
  key_state=missing
  [[ -f "$home/.ssh/authorized_keys" ]] && key_state=present
  sudo_state=missing
  [[ -f "$SUDOERS_DIR/homelab-agent-$user" ]] && sudo_state=present
  printf '%s\n' "-- $user --"
  printf '  Home:          %s\n' "$home"
  printf '  Shell:         %s\n' "$shell"
  printf '  State:         %s\n' "$state"
  printf '  Metadata:      version %s\n' "$metadata_version"
  printf '  Managed key:   %s\n' "$key_state"
  printf '  Sudo helper:   %s\n' "$sudo_state"
  printf '  Status list:   %s\n' "$status_allowlist_state"
  printf '  Log list:      %s\n' "$log_allowlist_state"
  printf '  Operations:    status, logs, ports, hardware (unit allowlists apply)\n\n'
done
REMOTE_SCRIPT
