#!/usr/bin/env bash
set -euo pipefail

###############################################################################
# ssh-readonly-user/remove
#
# Removes a readonly user from a remote server. Cleans up:
#   - User account and home directory
#   - Sudoers drop-in file
#   - SSH authorized_keys entry (if it was the only key)
#
# Usage:
#   ssh-readonly-user/remove user@host <readonly-username>
###############################################################################

usage() {
  cat >&2 <<EOF
Usage: $(basename "$0") user@host <readonly-username> [options]

Options:
  --keep-home    Don't delete the user's home directory
  --help         Show this help

Example:
  $(basename "$0") root@server agent
  $(basename "$0") admin@server monitor --keep-home
EOF
  exit 1
}

if [[ $# -lt 2 ]]; then
  usage
fi

REMOTE="$1"
READONLY_USER="$2"
shift 2 || true

KEEP_HOME=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --keep-home)
      KEEP_HOME=true
      shift
      ;;
    --help)
      usage
      ;;
    *)
      echo "Unknown option: $1" >&2
      usage
      ;;
  esac
done

if [[ "$REMOTE" != *@* ]]; then
  echo "Error: Remote must be in user@host format, got: $REMOTE" >&2
  exit 1
fi

echo "=== ssh-readonly-user/remove ==="
echo "  Remote:       $REMOTE"
echo "  User to remove: $READONLY_USER"
echo "  Keep home:    $KEEP_HOME"
echo ""

# ── SSH and teardown ────────────────────────────────────────────────────────
ssh -o StrictHostKeyChecking=accept-new "$REMOTE" bash -s \
  "$READONLY_USER" "$KEEP_HOME" << 'REMOTE_SCRIPT'
set -euo pipefail

READONLY_USER="$1"
KEEP_HOME="$2"

# ── Verify user exists ──────────────────────────────────────────────────────
if ! id "$READONLY_USER" &>/dev/null; then
  echo "[!] User '$READONLY_USER' does not exist on this system."
  exit 0
fi

echo "[*] Removing readonly user '$READONLY_USER'..."

# ── Phase 1: Remove sudoers drop-in ─────────────────────────────────────────
SUDOERS_FILE="/etc/sudoers.d/readonly-${READONLY_USER}"
if [[ -f "$SUDOERS_FILE" ]]; then
  rm -f "$SUDOERS_FILE"
  echo "[+] Removed $SUDOERS_FILE"
else
  echo "[i] No sudoers file found (already clean?)"
fi

# ── Phase 2: Remove SSH key from authorized_keys ────────────────────────────
HOME_DIR="$(eval echo ~$READONLY_USER)"
AUTH_KEYS="$HOME_DIR/.ssh/authorized_keys"

if [[ -f "$AUTH_KEYS" ]]; then
  # Remove lines that start with our hardening flags
  KEY_FLAGS="no-port-forwarding,no-X11-forwarding,no-agent-forwarding"
  sed -i "/^$KEY_FLAGS,/d" "$AUTH_KEYS"

  # If file is now empty, remove it (optional)
  if [[ ! -s "$AUTH_KEYS" ]]; then
    rm -f "$AUTH_KEYS"
    echo "[+] Removed empty authorized_keys"
  else
    echo "[+] Removed readonly key from authorized_keys"
  fi
fi

# ── Phase 3: Remove user account ────────────────────────────────────────────
if [[ "$KEEP_HOME" == "true" ]]; then
  # Remove user but keep home directory
  if command -v deluser &>/dev/null; then
    deluser "$READONLY_USER"
  elif command -v userdel &>/dev/null; then
    userdel "$READONLY_USER"
  fi
  echo "[+] Removed user '$READONLY_USER' (home kept at $HOME_DIR)"
else
  # Remove user and home directory
  if command -v deluser &>/dev/null; then
    deluser --remove-home "$READONLY_USER"
  elif command -v userdel &>/dev/null; then
    userdel -r "$READONLY_USER" 2>/dev/null || userdel "$READONLY_USER"
  fi
  echo "[+] Removed user '$READONLY_USER' and home directory"
fi

echo ""
echo "=== Done! User '$READONLY_USER' removed. ==="
REMOTE_SCRIPT
