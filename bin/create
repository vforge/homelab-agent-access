#!/usr/bin/env bash
set -euo pipefail

###############################################################################
# bin/create
#
# Provision a dedicated forced-command SSH account for read-oriented homelab
# inspection. The remote account has no interactive shell interface.
###############################################################################

usage() {
  cat >&2 <<'EOF'
Usage: create user@host /path/to/public-key.pub [options]

Options:
  --user <name>                 Remote account name (default: derived from key filename)
  --status-allowlist <file>    One allowed systemd unit per line for status requests
  --log-allowlist <file>       One allowed systemd unit per line for log requests
  --help                       Show this help

Both allowlist files are required. Blank lines and lines beginning with '#'
are ignored; an empty file denies that operation. The remote login must be
privileged. The target must already trust the administrator's host key; this
command uses StrictHostKeyChecking=yes.
EOF
  exit 2
}

if [[ $# -lt 2 ]]; then
  usage
fi

REMOTE="$1"
KEY_FILE="$2"
shift 2

READONLY_USER_OVERRIDE=""
STATUS_ALLOWLIST_FILE=""
LOG_ALLOWLIST_FILE=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --user)
      [[ $# -ge 2 ]] || usage
      READONLY_USER_OVERRIDE="$2"
      shift 2
      ;;
    --status-allowlist)
      [[ $# -ge 2 ]] || usage
      STATUS_ALLOWLIST_FILE="$2"
      shift 2
      ;;
    --log-allowlist)
      [[ $# -ge 2 ]] || usage
      LOG_ALLOWLIST_FILE="$2"
      shift 2
      ;;
    --help)
      usage
      ;;
    *)
      echo "Unknown option: $1" >&2
      usage
      ;;
  esac
done

if [[ -z "$STATUS_ALLOWLIST_FILE" || -z "$LOG_ALLOWLIST_FILE" ]]; then
  echo "Error: both --status-allowlist and --log-allowlist are required" >&2
  exit 1
fi

if [[ "$REMOTE" == -* || ! "$REMOTE" =~ ^[^@[:space:]]+@[^@[:space:]]+$ ]]; then
  echo "Error: remote must be in user@host format: $REMOTE" >&2
  exit 1
fi

if [[ ! -f "$KEY_FILE" || ! -r "$KEY_FILE" ]]; then
  echo "Error: public key file is not readable: $KEY_FILE" >&2
  exit 1
fi

# Require exactly one non-empty authorized-key line. This prevents newlines or
# authorized_keys options from becoming an input-injection mechanism.
line_count="$(grep -c '^' "$KEY_FILE" 2>/dev/null || true)"
if [[ "$line_count" != 1 ]]; then
  echo "Error: public key file must contain exactly one line" >&2
  exit 1
fi

PUBLIC_KEY="$(cat "$KEY_FILE")"
if [[ "$PUBLIC_KEY" == *$'\n'* || "$PUBLIC_KEY" == *$'\r'* ]]; then
  echo "Error: public key contains a newline" >&2
  exit 1
fi

read -r KEY_TYPE KEY_DATA _ <<< "$PUBLIC_KEY"
if [[ ! "$KEY_TYPE" =~ ^(ssh-ed25519|ssh-rsa|ecdsa-sha2-nistp[0-9]+|sk-ssh-ed25519@openssh.com|sk-ecdsa-sha2-nistp256@openssh.com)$ ]]; then
  echo "Error: unsupported or malformed public-key type" >&2
  exit 1
fi
if [[ ! "$KEY_DATA" =~ ^[A-Za-z0-9+/]+={0,2}$ ]]; then
  echo "Error: malformed public-key data" >&2
  exit 1
fi
if ! ssh-keygen -lf "$KEY_FILE" >/dev/null 2>&1; then
  echo "Error: ssh-keygen could not validate the public key" >&2
  exit 1
fi

KEY_BASENAME="${KEY_FILE##*/}"
KEY_BASENAME="${KEY_BASENAME%.pub}"
if [[ -n "$READONLY_USER_OVERRIDE" ]]; then
  READONLY_USER="$READONLY_USER_OVERRIDE"
elif [[ "$KEY_BASENAME" == id_* ]]; then
  READONLY_USER="${KEY_BASENAME##id_*_}"
else
  READONLY_USER="$KEY_BASENAME"
fi

if [[ ! "$READONLY_USER" =~ ^[a-z_][a-z0-9_-]{0,31}$ || "$READONLY_USER" == root ]]; then
  echo "Error: invalid or reserved account name: $READONLY_USER" >&2
  exit 1
fi

UNIT_PATTERN='[A-Za-z0-9_.@:][A-Za-z0-9_.@:-]*'
validate_allowlist() {
  local file="$1" line
  if [[ ! -f "$file" || ! -r "$file" || -L "$file" ]]; then
    echo "Error: allowlist file is not a readable regular file: $file" >&2
    exit 1
  fi
  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ "$line" != *$'\r'* ]] || {
      echo "Error: allowlist contains a carriage return: $file" >&2
      exit 1
    }
    [[ -z "$line" || "$line" == \#* ]] && continue
    [[ "$line" =~ ^$UNIT_PATTERN$ ]] || {
      echo "Error: invalid systemd unit in allowlist $file: $line" >&2
      exit 1
    }
  done < "$file"
}
validate_allowlist "$STATUS_ALLOWLIST_FILE"
validate_allowlist "$LOG_ALLOWLIST_FILE"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
DISPATCHER_FILE="$SCRIPT_DIR/remote/homelab-agent-dispatch"
ROOT_HELPER_FILE="$SCRIPT_DIR/remote/homelab-agent-dispatch-root"
for file in "$DISPATCHER_FILE" "$ROOT_HELPER_FILE"; do
  [[ -f "$file" ]] || { echo "Error: missing helper template: $file" >&2; exit 1; }
done

encode_file() {
  local encoded
  encoded="$(base64 < "$1" | tr -d '\n')"
  # SSH joins remote-command arguments with spaces; keep an empty allowlist
  # argument non-empty while preserving its empty/ignored-line semantics.
  [[ -n "$encoded" ]] || encoded='Cg=='
  printf '%s' "$encoded"
}

PUBLIC_KEY_B64="$(printf '%s' "$PUBLIC_KEY" | base64 | tr -d '\n')"
DISPATCHER_B64="$(encode_file "$DISPATCHER_FILE")"
ROOT_HELPER_B64="$(encode_file "$ROOT_HELPER_FILE")"
STATUS_ALLOWLIST_B64="$(encode_file "$STATUS_ALLOWLIST_FILE")"
LOG_ALLOWLIST_B64="$(encode_file "$LOG_ALLOWLIST_FILE")"

printf 'Provisioning forced-command access for %s on %s\n' "$READONLY_USER" "$REMOTE"
printf 'Public key: %s\n' "$KEY_FILE"

ssh \
  -o BatchMode=yes \
  -o RequestTTY=no \
  -o StrictHostKeyChecking=yes \
  -o ConnectTimeout=10 \
  -- "$REMOTE" bash -s -- \
  "$READONLY_USER" "$PUBLIC_KEY_B64" "$DISPATCHER_B64" "$ROOT_HELPER_B64" \
  "$STATUS_ALLOWLIST_B64" "$LOG_ALLOWLIST_B64" <<'REMOTE_SCRIPT'
set -euo pipefail

[[ $# -eq 6 ]] || { echo "invalid provisioning payload" >&2; exit 64; }
READONLY_USER="$1"
PUBLIC_KEY_B64="$2"
DISPATCHER_B64="$3"
ROOT_HELPER_B64="$4"
STATUS_ALLOWLIST_B64="$5"
LOG_ALLOWLIST_B64="$6"

if [[ ! "$READONLY_USER" =~ ^[a-z_][a-z0-9_-]{0,31}$ || "$READONLY_USER" == root ]]; then
  echo "invalid account name" >&2
  exit 64
fi

for required in id getent useradd usermod install mktemp base64 sudo visudo stat cmp; do
  command -v "$required" >/dev/null 2>&1 || {
    echo "required remote command is missing: $required" >&2
    exit 69
  }
done
[[ -x /usr/bin/sudo ]] || {
  echo "expected sudo path is missing: /usr/bin/sudo" >&2
  exit 69
}

PUBLIC_KEY="$(printf '%s' "$PUBLIC_KEY_B64" | base64 -d)"
DISPATCHER_TMP="$(mktemp)"
ROOT_HELPER_TMP="$(mktemp)"
STATUS_ALLOWLIST_TMP="$(mktemp)"
LOG_ALLOWLIST_TMP="$(mktemp)"
AUTH_TMP="$(mktemp)"
SUDOERS_TMP="$(mktemp)"
MARKER_TMP=""
cleanup() {
  rm -f "$DISPATCHER_TMP" "$ROOT_HELPER_TMP" "$STATUS_ALLOWLIST_TMP" \
    "$LOG_ALLOWLIST_TMP" "$AUTH_TMP" "$SUDOERS_TMP" "$MARKER_TMP"
}
trap cleanup EXIT
printf '%s' "$DISPATCHER_B64" | base64 -d > "$DISPATCHER_TMP"
printf '%s' "$ROOT_HELPER_B64" | base64 -d > "$ROOT_HELPER_TMP"
printf '%s' "$STATUS_ALLOWLIST_B64" | base64 -d > "$STATUS_ALLOWLIST_TMP"
printf '%s' "$LOG_ALLOWLIST_B64" | base64 -d > "$LOG_ALLOWLIST_TMP"

UNIT_PATTERN='[A-Za-z0-9_.@:][A-Za-z0-9_.@:-]*'
validate_allowlist() {
  local file="$1" line
  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ "$line" != *$'\r'* ]] || {
      echo "invalid allowlist content" >&2
      exit 65
    }
    [[ -z "$line" || "$line" == \#* ]] && continue
    [[ "$line" =~ ^$UNIT_PATTERN$ ]] || {
      echo "invalid systemd unit in allowlist" >&2
      exit 65
    }
  done < "$file"
}
validate_allowlist "$STATUS_ALLOWLIST_TMP"
validate_allowlist "$LOG_ALLOWLIST_TMP"
chmod 755 "$DISPATCHER_TMP" "$ROOT_HELPER_TMP"

MANAGED_DIR="/etc/homelab-agent-access"
ACCOUNTS_DIR="$MANAGED_DIR/accounts"
MARKER="$ACCOUNTS_DIR/$READONLY_USER"
LEGACY_MARKER="$MANAGED_DIR/$READONLY_USER"
EXPECTED_HOME="/home/$READONLY_USER"
DISPATCHER_PATH="/usr/local/sbin/homelab-agent-dispatch"
ROOT_HELPER_PATH="/usr/local/sbin/homelab-agent-dispatch-root"
STATUS_ALLOWLIST_PATH="$MANAGED_DIR/status-allowlist"
LOG_ALLOWLIST_PATH="$MANAGED_DIR/log-allowlist"
SUDOERS_FILE="/etc/sudoers.d/homelab-agent-$READONLY_USER"
MANAGED_BEGIN="# BEGIN homelab-agent-access managed key"
MANAGED_END="# END homelab-agent-access managed key"
KEY_OPTIONS='no-port-forwarding,no-X11-forwarding,no-agent-forwarding,no-pty,no-user-rc,command="/usr/local/sbin/homelab-agent-dispatch"'
NEW_ACCOUNT=false
MIGRATE_LEGACY=false

install -d -o root -g root -m 755 "$MANAGED_DIR"
install -d -o root -g root -m 755 "$ACCOUNTS_DIR"
if id "$READONLY_USER" >/dev/null 2>&1; then
  if [[ -f "$MARKER" && ! -L "$MARKER" ]]; then
    : # Version-3 metadata is verified after reading the passwd entry.
  elif [[ -f "$LEGACY_MARKER" && ! -L "$LEGACY_MARKER" && "$(<"$LEGACY_MARKER")" == version=2 ]]; then
    MIGRATE_LEGACY=true
  else
    echo "refusing to modify unmanaged or unsupported account: $READONLY_USER" >&2
    exit 73
  fi
  echo "Updating managed account '$READONLY_USER'"
else
  if [[ -e "$MARKER" || -L "$MARKER" || -e "$LEGACY_MARKER" || -L "$LEGACY_MARKER" ]]; then
    echo "refusing to recreate account with stale management metadata: $READONLY_USER" >&2
    exit 73
  fi
  [[ -d /home && ! -L /home ]] || {
    echo "expected a real /home directory" >&2
    exit 65
  }
  useradd --create-home --home-dir "$EXPECTED_HOME" --shell /bin/bash --password '!' "$READONLY_USER"
  NEW_ACCOUNT=true
  echo "Created account '$READONLY_USER'"
fi

ACCOUNT_UID=""
HOME_DIR=""
IFS=: read -r _ _ ACCOUNT_UID _ _ HOME_DIR _ < <(getent passwd "$READONLY_USER")
if [[ ! "$ACCOUNT_UID" =~ ^[0-9]+$ || "$ACCOUNT_UID" -eq 0 ]]; then
  echo "invalid or privileged account uid" >&2
  exit 65
fi
if [[ "$HOME_DIR" != "$EXPECTED_HOME" || ! -d "$HOME_DIR" || -L "$HOME_DIR" || -L /home ]]; then
  echo "unsafe account home directory: $HOME_DIR" >&2
  exit 65
fi

EXPECTED_MARKER="$(printf 'version=3\nuser=%s\nuid=%s\nhome=%s\n' \
  "$READONLY_USER" "$ACCOUNT_UID" "$HOME_DIR")"
if [[ -f "$MARKER" ]] && ! cmp -s <(printf '%s\n' "$EXPECTED_MARKER") "$MARKER"; then
  echo "managed-account metadata does not match passwd state: $READONLY_USER" >&2
  exit 73
fi
if [[ "$MIGRATE_LEGACY" == true && "$HOME_DIR" != "$EXPECTED_HOME" ]]; then
  echo "legacy account requires manual migration because its home is nonstandard" >&2
  exit 73
fi
if [[ "$NEW_ACCOUNT" == false && "$(stat -c '%u' "$HOME_DIR")" -ne 0 ]]; then
  echo "managed account home is not root-owned" >&2
  exit 73
fi

# The account is controlled by the forced key, not by a writable shell profile.
usermod --shell /bin/bash --lock "$READONLY_USER"
chown root:root "$HOME_DIR"
chmod 755 "$HOME_DIR"

install -d -o root -g root -m 755 /usr/local/sbin
install -o root -g root -m 755 "$DISPATCHER_TMP" "$DISPATCHER_PATH"
install -o root -g root -m 755 "$ROOT_HELPER_TMP" "$ROOT_HELPER_PATH"
install -o root -g root -m 444 "$STATUS_ALLOWLIST_TMP" "$STATUS_ALLOWLIST_PATH"
install -o root -g root -m 444 "$LOG_ALLOWLIST_TMP" "$LOG_ALLOWLIST_PATH"

SSH_DIR="$HOME_DIR/.ssh"
AUTH_KEYS="$SSH_DIR/authorized_keys"
install -d -o root -g root -m 700 "$SSH_DIR"
: > "$AUTH_TMP"

if [[ -f "$AUTH_KEYS" ]]; then
  in_managed=false
  while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ "$line" == "$MANAGED_BEGIN" ]]; then
      [[ "$in_managed" == false ]] || { echo "nested managed key block" >&2; exit 65; }
      in_managed=true
      continue
    fi
    if [[ "$line" == "$MANAGED_END" ]]; then
      [[ "$in_managed" == true ]] || { echo "unmatched managed key block" >&2; exit 65; }
      in_managed=false
      continue
    fi
    if [[ "$in_managed" == true ]]; then
      continue
    fi
    if [[ -z "$line" || "$line" == \#* ]]; then
      printf '%s\n' "$line" >> "$AUTH_TMP"
    else
      echo "refusing to overwrite unmanaged authorized_keys entry" >&2
      exit 73
    fi
  done < "$AUTH_KEYS"
  [[ "$in_managed" == false ]] || { echo "unterminated managed key block" >&2; exit 65; }
fi
{
  printf '%s\n' "$MANAGED_BEGIN"
  printf '%s %s\n' "$KEY_OPTIONS" "$PUBLIC_KEY"
  printf '%s\n' "$MANAGED_END"
} >> "$AUTH_TMP"
install -o root -g root -m 444 "$AUTH_TMP" "$AUTH_KEYS"

cat > "$SUDOERS_TMP" << SUDOERS
# Managed by homelab-agent-access. Do not edit manually.
${READONLY_USER} ALL=(root) NOPASSWD: ${ROOT_HELPER_PATH} ""
SUDOERS
chmod 440 "$SUDOERS_TMP"
chown root:root "$SUDOERS_TMP"
visudo -cf "$SUDOERS_TMP" >/dev/null
install -o root -g root -m 440 "$SUDOERS_TMP" "$SUDOERS_FILE"

MARKER_TMP="$(mktemp)"
printf '%s\n' "$EXPECTED_MARKER" > "$MARKER_TMP"
install -o root -g root -m 400 "$MARKER_TMP" "$MARKER"
rm -f "$MARKER_TMP"
if [[ "$MIGRATE_LEGACY" == true ]]; then
  rm -f "$LEGACY_MARKER"
fi

printf '%s\n' "Provisioned $READONLY_USER with forced operations:"
printf '%s\n' '  status UNIT (status allowlist enforced)'
printf '%s\n' '  logs UNIT LINES (1-500, log allowlist enforced)'
printf '%s\n' '  ports'
printf '%s\n' '  hardware'
REMOTE_SCRIPT
