#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat >&2 <<'EOF'
Usage: remove user@host <account> [options]

Options:
  --keep-home   Remove the account but preserve its home directory
  --help        Show this help
EOF
  exit "${1:-2}"
}

if [[ $# -eq 1 && "$1" == --help ]]; then
  usage 0
fi
[[ $# -ge 2 ]] || usage
REMOTE="$1"
READONLY_USER="$2"
shift 2
KEEP_HOME=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --keep-home)
      KEEP_HOME=true
      shift
      ;;
    --help)
      usage 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      usage
      ;;
  esac
done

if [[ "$REMOTE" == -* || ! "$REMOTE" =~ ^[^@[:space:]]+@[^@[:space:]]+$ ]]; then
  echo "Error: remote must be in user@host format: $REMOTE" >&2
  exit 1
fi
if [[ ! "$READONLY_USER" =~ ^[a-z_][a-z0-9_-]{0,31}$ || "$READONLY_USER" == root ]]; then
  echo "Error: invalid or reserved account name: $READONLY_USER" >&2
  exit 1
fi

printf 'Removing managed access for %s on %s\n' "$READONLY_USER" "$REMOTE"

ssh \
  -o BatchMode=yes \
  -o RequestTTY=no \
  -o StrictHostKeyChecking=yes \
  -o ConnectTimeout=10 \
  -- "$REMOTE" bash -s -- "$READONLY_USER" "$KEEP_HOME" <<'REMOTE_SCRIPT'
set -euo pipefail

[[ $# -eq 2 ]] || { echo "invalid removal payload" >&2; exit 64; }
READONLY_USER="$1"
KEEP_HOME="$2"
[[ "$READONLY_USER" =~ ^[a-z_][a-z0-9_-]{0,31}$ && "$READONLY_USER" != root ]] || {
  echo "invalid account name" >&2
  exit 64
}

for required in id getent userdel rm install stat cmp; do
  command -v "$required" >/dev/null 2>&1 || {
    echo "required remote command is missing: $required" >&2
    exit 69
  }
done

MANAGED_DIR="/etc/homelab-agent-access"
ACCOUNTS_DIR="$MANAGED_DIR/accounts"
MARKER="$ACCOUNTS_DIR/$READONLY_USER"
LEGACY_MARKER="$MANAGED_DIR/$READONLY_USER"
EXPECTED_HOME="/home/$READONLY_USER"
SUDOERS_FILE="/etc/sudoers.d/homelab-agent-$READONLY_USER"
MANAGED_BEGIN="# BEGIN homelab-agent-access managed key"
MANAGED_END="# END homelab-agent-access managed key"

if [[ -f "$LEGACY_MARKER" || -L "$LEGACY_MARKER" ]]; then
  echo "Legacy account metadata must be upgraded with bin/create before removal: $READONLY_USER" >&2
  exit 73
fi
if [[ ! -f "$MARKER" || -L "$MARKER" ]]; then
  echo "Refusing to remove unmanaged account: $READONLY_USER" >&2
  exit 73
fi
if [[ "$(stat -c '%u' "$MARKER")" -ne 0 || "$(stat -c '%a' "$MARKER")" != 400 ]]; then
  echo "Refusing account with unsafe management metadata: $READONLY_USER" >&2
  exit 73
fi

EXPECTED_SUDOERS="$(printf '%s\n%s ALL=(root) NOPASSWD: /usr/local/sbin/homelab-agent-dispatch-root \"\"' \
  '# Managed by homelab-agent-access. Do not edit manually.' "$READONLY_USER")"
validate_sudoers_file() {
  if [[ -L "$SUDOERS_FILE" || ( -e "$SUDOERS_FILE" && ! -f "$SUDOERS_FILE" ) ]]; then
    echo "unsafe sudoers path" >&2
    exit 73
  fi
  if [[ -f "$SUDOERS_FILE" ]]; then
    if [[ "$(stat -c '%u' "$SUDOERS_FILE")" -ne 0 || \
          "$(stat -c '%a' "$SUDOERS_FILE")" != 440 ]] || \
       ! cmp -s <(printf '%s\n' "$EXPECTED_SUDOERS") "$SUDOERS_FILE"; then
      echo "refusing to remove invalid or unsafe sudoers file" >&2
      exit 73
    fi
  fi
}
validate_sudoers_file

if ! id "$READONLY_USER" >/dev/null 2>&1; then
  marker_lines=()
  mapfile -t marker_lines < "$MARKER"
  if [[ ${#marker_lines[@]} -ne 4 || \
        "${marker_lines[0]}" != version=3 || \
        "${marker_lines[1]}" != "user=$READONLY_USER" || \
        ! "${marker_lines[2]}" =~ ^uid=([0-9]+)$ || \
        "${BASH_REMATCH[1]}" -eq 0 || \
        "${marker_lines[3]}" != "home=$EXPECTED_HOME" ]]; then
    echo "refusing stale cleanup with invalid management metadata: $READONLY_USER" >&2
    exit 73
  fi
  rm -f "$MARKER" "$SUDOERS_FILE"
  echo "Account was already absent; removed verified stale management files."
  exit 0
fi

ACCOUNT_UID=""
HOME_DIR=""
IFS=: read -r _ _ ACCOUNT_UID _ _ HOME_DIR _ < <(getent passwd "$READONLY_USER")
if [[ ! "$ACCOUNT_UID" =~ ^[0-9]+$ || "$ACCOUNT_UID" -eq 0 ]]; then
  echo "invalid or privileged account uid" >&2
  exit 65
fi
if [[ "$HOME_DIR" != "$EXPECTED_HOME" || ! -d "$HOME_DIR" || -L "$HOME_DIR" || -L /home ]]; then
  echo "unsafe account home directory: $HOME_DIR" >&2
  exit 65
fi
EXPECTED_MARKER="$(printf 'version=3\nuser=%s\nuid=%s\nhome=%s\n' \
  "$READONLY_USER" "$ACCOUNT_UID" "$HOME_DIR")"
if ! cmp -s <(printf '%s\n' "$EXPECTED_MARKER") "$MARKER"; then
  echo "managed-account metadata does not match passwd state: $READONLY_USER" >&2
  exit 73
fi
if [[ "$(stat -c '%u' "$HOME_DIR")" -ne 0 ]]; then
  echo "managed account home is not root-owned" >&2
  exit 73
fi

SSH_DIR="$HOME_DIR/.ssh"
AUTH_KEYS="$SSH_DIR/authorized_keys"
if [[ -L "$SSH_DIR" || ( -e "$SSH_DIR" && ! -d "$SSH_DIR" ) || -L "$AUTH_KEYS" ]]; then
  echo "unsafe account SSH path" >&2
  exit 73
fi
if [[ -e "$SSH_DIR" ]] && {
  [[ "$(stat -c '%u' "$SSH_DIR")" -ne 0 || "$(stat -c '%a' "$SSH_DIR")" != 755 ]];
}; then
  echo "unsafe account SSH directory ownership or mode" >&2
  exit 73
fi
if [[ -f "$AUTH_KEYS" ]]; then
  if [[ "$(stat -c '%u' "$AUTH_KEYS")" -ne 0 || "$(stat -c '%a' "$AUTH_KEYS")" != 444 ]]; then
    echo "unsafe authorized_keys ownership or mode" >&2
    exit 73
  fi
  AUTH_TMP="$(mktemp)"
  cleanup() { rm -f "$AUTH_TMP"; }
  trap cleanup EXIT
  in_managed=false
  while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ "$line" == "$MANAGED_BEGIN" ]]; then
      [[ "$in_managed" == false ]] || { echo "nested managed key block" >&2; exit 65; }
      in_managed=true
      continue
    fi
    if [[ "$line" == "$MANAGED_END" ]]; then
      [[ "$in_managed" == true ]] || { echo "unmatched managed key block" >&2; exit 65; }
      in_managed=false
      continue
    fi
    [[ "$in_managed" == true ]] || printf '%s\n' "$line" >> "$AUTH_TMP"
  done < "$AUTH_KEYS"
  [[ "$in_managed" == false ]] || { echo "unterminated managed key block" >&2; exit 65; }
  if [[ -s "$AUTH_TMP" ]]; then
    install -o root -g root -m 444 "$AUTH_TMP" "$AUTH_KEYS"
  else
    rm -f "$AUTH_KEYS"
  fi
fi

rm -f "$SUDOERS_FILE"
userdel "$READONLY_USER"
if [[ "$KEEP_HOME" == true ]]; then
  echo "Removed account '$READONLY_USER'; preserved home at $HOME_DIR"
else
  # userdel --remove commonly refuses a root-owned home. The path and metadata
  # were verified above, so remove that exact canonical home explicitly.
  rm -rf --one-file-system -- "$HOME_DIR"
  echo "Removed account '$READONLY_USER' and home directory"
fi
rm -f "$MARKER"
REMOTE_SCRIPT
